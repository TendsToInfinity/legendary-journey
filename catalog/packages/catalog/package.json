{
  "name": "catalog-task",
  "version": "15.0.1",
  "description": "Catalog Service",
  "main": "dist/src/main.js",
  "directories": {
    "test": "test"
  },
  "author": "James Brooks",
  "license": "ISC",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "jsonschema:init": "jsp schema:init -s src/**/models/**/*.ts db/reference/*Schema.ts -a autoComplete requiredIfActive keyField distinctValue readonly context",
    "db:init": "es templates:apply --paths \"../../node_modules/securus.tablets.elasticsearch.templates/sv_catalog_template.json\" && pg schema:apply && audit-history schema:apply && pg schema:migrate && node ./dist/db/cli.js generate-schemas && node ./dist/db/cli.js put-templates && context-config schema:apply",
    "start": "yarn run -T ts-node src/main.ts",
    "prestart": "yarn run swagger && yarn run jsonschema:init",
    "clean": "rimraf dist/",
    "build-tsc": "yarn run -T tsc -b -v",
    "swagger": "echo \"API docs are disabled for now :/\"",
    "build": "yarn run build-tsc && yarn run swagger && yarn run jsonschema:init",
    "build-debug": "tsc -p tsconfig.debug.json && yarn run swagger",
    "rage-clean": "rimraf node_modules/ && npm cache clean",
    "ci": "yarn run clean && yarn run build && yarn run lint && yarn run coverage && yarn run mutation && yarn run integration-test",
    "watch-server": "nodemon --ext ts --ignore test/ --exec npm start",
    "watch-test": "cross-env NODE_ENV=test nodemon --ext ts --exec mocha --require ts-node/register",
    "watch-tests": "cross-env NODE_ENV=test nodemon --ext ts --exec mocha --require ts-node/register \"test/**/*.spec.ts\""
  },
  "dependencies": {
    "@opensearch-project/opensearch": "^2.1.0",
    "@securustablets/libraries.audit-history": "^3.1.2",
    "@securustablets/libraries.cache": "^3.0.1",
    "@securustablets/libraries.cache-local": "^1.0.0",
    "@securustablets/libraries.cache-memcache": "^1.4.3",
    "@securustablets/libraries.config": "^1.0.0",
    "@securustablets/libraries.context-config": "6.0.3",
    "@securustablets/libraries.httpsecurity": "^5.7.0",
    "@securustablets/libraries.json-schema": "^6.0.0",
    "@securustablets/libraries.logging": "^4.0.0",
    "@securustablets/libraries.messaging": "^8.0.0",
    "@securustablets/libraries.postgres": "^4.3.1",
    "@securustablets/libraries.utils": "^1.0.1",
    "@securustablets/services.eligibility.client": "^3.4.2",
    "@securustablets/services.inmate.client": "^8.0.0",
    "amqplib": "^0.9.0",
    "async-retry": "^1.3.3",
    "aws-xray-sdk-core": "^3.3.4",
    "aws-xray-sdk-express": "^3.3.4",
    "aws-xray-sdk-postgres": "^3.3.4",
    "axios": "^1.7.4",
    "bluebird": "~3.7.2",
    "config": "^4.4.1",
    "cors": "~2.8.5",
    "dd-trace": "^3.22.0",
    "elastic-apm-node": "4.8.0",
    "elasticsearch": "16.7.2",
    "express": "4.21.2",
    "fs-extra": "~10.0.0",
    "glob": "^13.0.6",
    "jsonschema": "^1.4.1",
    "jsonwebtoken": "9.0.0",
    "pg": "^8.7.1",
    "pg-format": "^1.0.4",
    "securus.libraries.elasticsearch-promise": "^3.0.0",
    "securus.libraries.expressApi": "^8.1.1",
    "securus.tablets.elasticsearch.templates": "^2.4.0",
    "securus.tablets.external.tsoa": "^3.0.3",
    "securus.tablets.libraries.exceptions": "^2.0.0",
    "swagger-ui-express": "~4.3.0",
    "typescript-ioc": "^1.2.5",
    "typescript-json-schema": "~0.67.1",
    "yargs": "~17.3.1"
  },
  "devDependencies": {
    "@securustablets/libraries.context-config.client": "6.0.3",
    "@securustablets/libraries.utils-test": "^6.0.0",
    "@types/amqplib": "~0.5.13",
    "@types/aws4": "^1.11.2",
    "@types/bluebird": "3.5.37",
    "@types/chai": "~4.1.7",
    "@types/chai-as-promised": "7.1.0",
    "@types/cors": "~2.8.3",
    "@types/elasticsearch": "5.0.29",
    "@types/express": "^4",
    "@types/express-serve-static-core": "4.17.30",
    "@types/faker": "~4.1.5",
    "@types/fs-extra": "5.0.0",
    "@types/jsonwebtoken": "~7.2.8",
    "@types/node": "^24.10.13",
    "@types/pg": "~7.4.14",
    "@types/pg-format": "^1.0.2",
    "@types/sinon": "5.0.1",
    "@types/superagent": "~3.8.4",
    "@types/supertest": "~2.0.6",
    "@types/uuid": "~3.4.4",
    "@types/yargs": "^16",
    "chai": "~4.2.0",
    "chai-as-promised": "~7.1.1",
    "cpx": "~1.5.0",
    "faker": "~4.1.0",
    "is-port-reachable": "~3.0.0",
    "json-schema-faker": "0.5.0-rc16",
    "mock-require": "~3.0.3",
    "moment": "~2.29.4",
    "moxios": "^0.4.0",
    "ms": "~2.1.1",
    "nodemon": "~2.0.3",
    "opn-cli": "~3.1.0",
    "rimraf": "~2.6.2",
    "securus.tablets.elasticsearch.utils": "^2.0.0",
    "securus.tablets.models.common": "^1.2.0",
    "sinon": "~6.3.5",
    "supertest": "~3.3.0",
    "ts-node": "^10.9.2"
  }
}
