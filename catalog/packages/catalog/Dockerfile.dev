FROM mi-nexus02.dal.securustech.net:8080/base/nodejs:24

ADD https://github.com/ufoscout/docker-compose-wait/releases/download/2.7.3/wait /wait
RUN chmod +x /wait

WORKDIR /code
RUN useradd --uid 1000 --user-group --shell /bin/bash --create-home node
RUN chown node:node .
USER node

COPY --chown=node:node package.json yarn.lock .yarnrc.yml ./
RUN yarn install
COPY --chown=node:node . .
RUN yarn run build

CMD ["/bin/bash", "-c", "/wait && yarn run db:init && yarn start"]
