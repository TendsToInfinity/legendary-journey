<!-- This configuration for Webstorm allows running mocha tests through ide by adding the require ts-node/register option to all unit tests-->
<component name="ProjectRunConfigurationManager">
  <configuration default="true" type="mocha-javascript-test-runner">
    <node-interpreter>project</node-interpreter>
    <node-options />
    <working-directory />
    <pass-parent-env>true</pass-parent-env>
    <ui />
    <extra-mocha-options>--require ts-node/register</extra-mocha-options>
    <test-kind>DIRECTORY</test-kind>
    <test-directory />
    <recursive>false</recursive>
    <method v="2" />
  </configuration>
</component>